@model OrderVM

<form method="post">
    <input asp-for="OrderHeader.Id" hidden />

    <div class="may-order-page">
        <div class="container may-order-shell py-4">
            <div class="may-order-card">

                <div class="may-order-topbar">
                    <div class="row align-items-center g-3">
                        <div class="col-12 col-lg-7">
                            <div class="may-eyebrow">MAY Business Suite</div>
                            <h2 class="may-page-title">Bestelling Details</h2>
                            <p class="may-page-subtitle mb-0">
                                Beheer klantgegevens, verzending en bestelstatus in één overzicht.
                            </p>
                        </div>

                        <div class="col-12 col-lg-5 text-lg-end">
                            <a asp-action="Index" class="btn may-btn may-btn-topbar">
                                <span class="may-btn-icon">←</span>
                                Terug naar overzicht
                            </a>
                        </div>
                    </div>
                </div>

                <div class="may-order-content">
                    <div class="row g-4">
                        <div class="col-12 col-xl-7">
                            <div class="may-panel may-panel-main">
                                <div class="may-section-heading">
                                    <div class="may-section-kicker">Klantinformatie</div>
                                    <h4>Leveringsgegevens</h4>
                                </div>

                                <div class="may-details-grid">
                                    <div class="may-field-row">
                                        <label class="may-field-label">Naam</label>
                                        <div class="may-field-control">
                                            @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
                                            {
                                                <input asp-for="OrderHeader.Name" type="text" class="form-control may-input" />
                                                <span asp-validation-for="OrderHeader.Name" class="text-danger"></span>
                                            }
                                            else
                                            {
                                                <input asp-for="OrderHeader.Name" type="text" readonly class="form-control may-input" />
                                            }
                                        </div>
                                    </div>

                                    <div class="may-field-row">
                                        <label class="may-field-label">Telefoon</label>
                                        <div class="may-field-control">
                                            @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
                                            {
                                                <input asp-for="OrderHeader.PhoneNumber" type="text" class="form-control may-input" />
                                                <span asp-validation-for="OrderHeader.PhoneNumber" class="text-danger"></span>
                                            }
                                            else
                                            {
                                                <input asp-for="OrderHeader.PhoneNumber" type="text" readonly class="form-control may-input" />
                                            }
                                        </div>
                                    </div>

                                    <div class="may-field-row">
                                        <label class="may-field-label">Adres</label>
                                        <div class="may-field-control">
                                            @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
                                            {
                                                <input asp-for="OrderHeader.StreetAddress" type="text" class="form-control may-input" />
                                                <span asp-validation-for="OrderHeader.StreetAddress" class="text-danger"></span>
                                            }
                                            else
                                            {
                                                <input asp-for="OrderHeader.StreetAddress" type="text" readonly class="form-control may-input" />
                                            }
                                        </div>
                                    </div>

                                    <div class="may-field-row">
                                        <label class="may-field-label">Stad</label>
                                        <div class="may-field-control">
                                            @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
                                            {
                                                <input asp-for="OrderHeader.City" type="text" class="form-control may-input" />
                                                <span asp-validation-for="OrderHeader.City" class="text-danger"></span>
                                            }
                                            else
                                            {
                                                <input asp-for="OrderHeader.City" type="text" readonly class="form-control may-input" />
                                            }
                                        </div>
                                    </div>

                                    <div class="may-field-row">
                                        <label class="may-field-label">Postcode</label>
                                        <div class="may-field-control">
                                            @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
                                            {
                                                <input asp-for="OrderHeader.PostalCode" type="text" class="form-control may-input" />
                                                <span asp-validation-for="OrderHeader.PostalCode" class="text-danger"></span>
                                            }
                                            else
                                            {
                                                <input asp-for="OrderHeader.PostalCode" type="text" readonly class="form-control may-input" />
                                            }
                                        </div>
                                    </div>

                                    <div class="may-field-row">
                                        <label class="may-field-label">E-mail</label>
                                        <div class="may-field-control">
                                            <input asp-for="OrderHeader.ApplicationUser.Email" type="text" readonly class="form-control may-input" />
                                        </div>
                                    </div>

                                    <div class="may-field-row">
                                        <label class="may-field-label">Besteldatum</label>
                                        <div class="may-field-control">
                                            <input value="@Model.OrderHeader.OrderDate.ToShortDateString()" type="text" readonly class="form-control may-input" />
                                        </div>
                                    </div>

                                    <div class="may-field-row">
                                        <label class="may-field-label">Vervoerder</label>
                                        <div class="may-field-control">
                                            @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
                                            {
                                                <input asp-for="OrderHeader.Carrier" id="carrier" type="text" class="form-control may-input" />
                                            }
                                            else
                                            {
                                                <input asp-for="OrderHeader.Carrier" type="text" readonly class="form-control may-input" />
                                            }
                                        </div>
                                    </div>

                                    <div class="may-field-row">
                                        <label class="may-field-label">Tracking</label>
                                        <div class="may-field-control">
                                            @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
                                            {
                                                <input asp-for="OrderHeader.TrackingNumber" id="trackingNumber" type="text" class="form-control may-input" />
                                            }
                                            else
                                            {
                                                <input asp-for="OrderHeader.TrackingNumber" type="text" readonly class="form-control may-input" />
                                            }
                                        </div>
                                    </div>

                                    <div class="may-field-row">
                                        <label class="may-field-label">Verzenddatum</label>
                                        <div class="may-field-control">
                                            <input value="@(Model.OrderHeader.ShippingDate.Year > 1 ? Model.OrderHeader.ShippingDate.ToShortDateString() : "-")" type="text" readonly class="form-control may-input" />
                                        </div>
                                    </div>

                                    <div class="may-field-row">
                                        <label class="may-field-label">Sessie ID</label>
                                        <div class="may-field-control">
                                            <input asp-for="OrderHeader.SessionId" type="text" readonly class="form-control may-input" />
                                        </div>
                                    </div>

                                    <div class="may-field-row">
                                        <label class="may-field-label">Betalings ID</label>
                                        <div class="may-field-control">
                                            <input asp-for="OrderHeader.PaymentIntentId" type="text" readonly class="form-control may-input" />
                                        </div>
                                    </div>

                                    <div class="may-field-row">
                                        @if (Model.OrderHeader.SessionId == null)
                                        {
                                            <label class="may-field-label">Uiterste betaaldatum</label>
                                            <div class="may-field-control">
                                                <input value="@Model.OrderHeader.PaymentDueDate.ToShortDateString()" type="text" readonly class="form-control may-input" />
                                            </div>
                                        }
                                        else
                                        {
                                            <label class="may-field-label">Betaaldatum</label>
                                            <div class="may-field-control">
                                                <input value="@Model.OrderHeader.PaymentDate.ToShortDateString()" type="text" readonly class="form-control may-input" />
                                            </div>
                                        }
                                    </div>

                                    <div class="may-field-row">
                                        <label class="may-field-label">Betaalstatus</label>
                                        <div class="may-field-control">
                                            <input asp-for="OrderHeader.PaymentStatus" type="text" readonly class="form-control may-input" />
                                        </div>
                                    </div>
                                </div>

                                @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
                                {
                                    <div class="may-bottom-actions">
                                        <button type="submit" asp-action="UpdateOrderDetail" class="btn may-btn may-btn-primary may-btn-full">
                                            Details bijwerken
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="col-12 col-xl-5">
                            <div class="may-panel may-panel-summary">
                                <div class="may-section-heading">
                                    <div class="may-section-kicker">Overzicht</div>
                                    <h4>Bestelling Samenvatting</h4>
                                </div>

                                <div class="may-status-card">
                                    <div>
                                        <div class="may-status-label">Status</div>
                                        <div class="may-status-note">Huidige fase van de bestelling</div>
                                    </div>
                                    <span class="may-status-badge">@Model.OrderHeader.OrderStatus</span>
                                </div>

                                <div class="may-items-list">
                                    @foreach (var detail in Model.OrderDetail)
                                    {
                                        <div class="may-item-card">
                                            <div class="may-item-left">
                                                <div class="may-item-name">@detail.Product.ProductName</div>
                                                <div class="may-item-meta">Prijs: @detail.Price.ToString("c")</div>
                                                <div class="may-item-meta">Aantal: @detail.Count</div>
                                            </div>
                                            <div class="may-item-total">
                                                @((detail.Count * detail.Price).ToString("c"))
                                            </div>
                                        </div>
                                    }
                                </div>

                                <div class="may-total-card">
                                    <span>Totaalbedrag</span>
                                    <strong>@Model.OrderHeader.OrderTotal.ToString("c")</strong>
                                </div>

                                @if (Model.OrderHeader.PaymentStatus == SD.PaymentStatusDelayedPayment && Model.OrderHeader.OrderStatus == SD.StatusShipped)
                                {
                                    <button type="submit" class="btn may-btn may-btn-success may-btn-full mb-3">
                                        Nu betalen
                                    </button>
                                }

                                @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
                                {
                                    <div class="may-action-stack">
                                        @if (Model.OrderHeader.OrderStatus == SD.StatusApproved)
                                        {
                                            <button asp-action="StartProcessing" type="submit" class="btn may-btn may-btn-success may-btn-full">
                                                Verwerking starten
                                            </button>
                                        }

                                        @if (Model.OrderHeader.OrderStatus == SD.StatusInProcess)
                                        {
                                            <button asp-action="ShipOrder" type="submit" onclick="return validateInput()" class="btn may-btn may-btn-secondary may-btn-full">
                                                Bestelling verzenden
                                            </button>
                                        }

                                        @if (Model.OrderHeader.OrderStatus != SD.StatusRefunded &&
                                                                            Model.OrderHeader.OrderStatus != SD.StatusCancelled &&
                                                                            Model.OrderHeader.OrderStatus != SD.StatusShipped)
                                        {
                                            <button asp-action="CancelOrder" type="submit" class="btn may-btn may-btn-danger may-btn-full">
                                                Bestelling annuleren
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function validateInput() {
            if (document.getElementById("trackingNumber").value == "") {
                Swal.fire({
                    icon: 'error',
                    title: 'Oeps...',
                    text: 'Voer aub een tracking nummer in!'
                })
                return false
            }
            if (document.getElementById("carrier").value == "") {
                Swal.fire({
                    icon: 'error',
                    title: 'Oeps...',
                    text: 'Voer aub een vervoerder in!'
                })
                return false
            }
            return true;
        }
    </script>
}