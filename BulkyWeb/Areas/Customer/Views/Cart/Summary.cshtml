@model ShoppingCartVM

<form method="post">
    <br />
    <div class="container d-flex justify-content-center align-items-center flex-grow-1" style="min-height: 80vh; padding-bottom: 50px;">
        <div class="col-12 col-lg-10">
            <div class="card shadow-lg border-0" style="border-radius: 20px; overflow: hidden;">

                <div class="card-header bg-primary py-4 border-0" style="background-color: var(--primary-dark) !important;">
                    <div class="row px-4">
                        <div class="col-6">
                            <h4 class="pt-2 text-white fw-bold">Besteloverzicht</h4>
                        </div>
                        <div class="col-6 text-end">
                            <a asp-action="Index" class="btn btn-outline-light border-0 rounded-3">Terug naar mandje</a>
                        </div>
                    </div>
                </div>

                <div class="card-body p-5">
                    <div class="row">
                        <div class="col-12 col-lg-6 pb-4">
                            <h4 class="mb-4 fw-bold text-dark border-bottom pb-2">Verzendgegevens</h4>

                            @* Backend Error Summary *@
                            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                            <div class="form-floating mb-3">
                                <input asp-for="OrderHeader.Name" class="form-control border-0 bg-light shadow-sm" style="border-radius: 12px;" placeholder="Naam" />
                                <label asp-for="OrderHeader.Name" class="text-muted">Volledige Naam</label>
                                <span asp-validation-for="OrderHeader.Name" class="text-danger small"></span>
                            </div>

                            <div class="form-floating mb-3">
                                <input asp-for="OrderHeader.PhoneNumber" class="form-control border-0 bg-light shadow-sm" style="border-radius: 12px;" placeholder="Telefoon" />
                                <label asp-for="OrderHeader.PhoneNumber" class="text-muted">Telefoonnummer</label>
                                <span asp-validation-for="OrderHeader.PhoneNumber" class="text-danger small"></span>
                            </div>

                            <div class="form-floating mb-3">
                                <input asp-for="OrderHeader.StreetAddress" class="form-control border-0 bg-light shadow-sm" style="border-radius: 12px;" placeholder="Adres" />
                                <label asp-for="OrderHeader.StreetAddress" class="text-muted">Straat & Huisnummer</label>
                                <span asp-validation-for="OrderHeader.StreetAddress" class="text-danger small"></span>
                            </div>

                            <div class="row g-2">
                                <div class="form-floating col-md-8 mb-3">
                                    <input asp-for="OrderHeader.City" class="form-control border-0 bg-light shadow-sm" style="border-radius: 12px;" placeholder="Stad" />
                                    <label asp-for="OrderHeader.City" class="ms-2 text-muted">Stad</label>
                                    <span asp-validation-for="OrderHeader.City" class="text-danger small"></span>
                                </div>
                                <div class="form-floating col-md-4 mb-3">
                                    <input asp-for="OrderHeader.PostalCode" class="form-control border-0 bg-light shadow-sm" style="border-radius: 12px;" placeholder="Postcode" />
                                    <label asp-for="OrderHeader.PostalCode" class="ms-2 text-muted">Postcode</label>
                                    <span asp-validation-for="OrderHeader.PostalCode" class="text-danger small"></span>
                                </div>
                            </div>

                            @* State is hier weggelaten of kan als optioneel veld onderaan *@
                        </div>

                        <div class="col-12 col-lg-5 offset-lg-1">
                            <h4 class="mb-4 fw-bold text-dark border-bottom pb-2">Jouw Producten</h4>
                            <ul class="list-group list-group-flush mb-3">
                                @foreach (var details in Model.ShoppingCartList)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center border-0 px-0 bg-transparent">
                                        <div>
                                            <h6 class="my-0 fw-bold">@details.Product.ProductName</h6>
                                            <small class="text-muted">Aantal: @details.Count</small>
                                        </div>
                                        <span class="fw-bold text-dark">@((details.Price * details.Count).ToString("c"))</span>
                                    </li>
                                }
                                <li class="list-group-item d-flex justify-content-between align-items-center border-0 px-0 bg-transparent mt-3 border-top pt-3">
                                    <h5 class="fw-bolder text-primary">Totaal (EUR)</h5>
                                    <h5 class="fw-bolder text-primary">@Model.OrderHeader.OrderTotal.ToString("c")</h5>
                                </li>
                            </ul>

                            <div class="card bg-light border-0 rounded-4 p-3 mt-4">
                                <p class="small text-muted mb-0">
                                    <i class="bi bi-truck me-2"></i> Verwachte levering:
                                    <strong>@DateTime.Now.AddDays(2).ToShortDateString() - @DateTime.Now.AddDays(5).ToShortDateString()</strong>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-white p-4 border-0">
                    <div class="row">
                        <div class="col-12 col-md-6 offset-md-6">
                            <button type="submit" value="Place Order" class="btn btn-primary w-100 py-3 shadow-sm border-0 bg-gradient rounded-3 text-uppercase fw-bold" style="background-color: var(--primary-dark) !important;">
                                Bestelling Plaatsen
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}