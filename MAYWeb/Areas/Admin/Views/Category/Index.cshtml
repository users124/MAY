@model List<Category>

<div class="container mt-5">
    <div class="row align-items-center mb-4">
        <div class="col-6">
            <h1 class="fw-bold text-dark m-0" style="letter-spacing: -1px;">Categorie Overzicht</h1>
            <p class="text-muted small">Beheer de productcategorieën voor MAY_business</p>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="Category" asp-action="Create" class="btn btn-dark px-4 py-2 rounded-pill shadow-sm">
                <i class="bi bi-plus-circle me-2"></i>Nieuwe Categorie
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <table class="table table-hover mb-0 custom-table">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase fs-7 fw-bold text-secondary" style="font-size: 0.75rem; letter-spacing: 1px;">
                            Categorie Naam
                        </th>
                        <th class="py-3 text-uppercase fs-7 fw-bold text-secondary" style="font-size: 0.75rem; letter-spacing: 1px;">
                            Display Order
                        </th>
                        <th class="pe-4 py-3 text-end text-uppercase fs-7 fw-bold text-secondary" style="font-size: 0.75rem; letter-spacing: 1px;">
                            Acties
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var obj in Model.OrderBy(u => u.DisplayOrder))
                    {
                        <tr>
                            <td class="ps-4 py-3 align-middle">
                                <span class="fw-semibold text-dark">@obj.Name</span>
                            </td>
                            <td class="py-3 align-middle">
                                <span class="badge bg-light text-dark border px-3 py-2 rounded-3">@obj.DisplayOrder</span>
                            </td>
                            <td class="pe-4 py-3 text-end align-middle">
                                <div class="btn-group shadow-sm rounded-3 overflow-hidden" role="group">
                                    <a asp-controller="Category" asp-action="Edit" asp-route-id="@obj.Id" class="btn btn-white btn-sm border-end px-3" title="Bewerken">
                                        <i class="bi bi-pencil-square text-primary"></i>
                                    </a>
                                    <a asp-controller="Category" asp-action="Delete" asp-route-id="@obj.Id" class="btn btn-white btn-sm px-3" title="Verwijderen">
                                        <i class="bi bi-trash-fill text-danger"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
