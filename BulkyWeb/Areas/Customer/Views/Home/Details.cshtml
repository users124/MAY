@model ShoppingCart

<form method="post">
    <input asp-for="ProductId" hidden />

    <div class="container py-4">
        <div class="product-detail-card shadow-sm">
            <div class="row g-5 align-items-start">

                <div class="col-lg-6">
                    <a asp-action="Index" class="back-link">← Terug naar overzicht</a>

                    <div class="product-image-box mt-3">
                        <img src="@Model.Product.ImageUrl" alt="@Model.Product.ProductName" class="product-main-image" />
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="product-content">

                        <span class="sku-label">@Model.Product.Category.Name</span>

                        <h1 class="product-detail-title mt-3">@Model.Product.ProductName</h1>

                        <div class="price-card mt-4">
                            <div class="old-price">
                                Adviesprijs:
                                <span>€ @Model.Product.ListPrice.ToString("0.00")</span>
                            </div>

                            <div class="tier-pricing mt-3">
                                <div class="tier-row tier-header">
                                    <div>Aantal</div>
                                    <div>1 - 50</div>
                                    <div>51 - 100</div>
                                    <div>100+</div>
                                </div>

                                <div class="tier-row">
                                    <div class="tier-label">Prijs</div>
                                    <div>€ @Model.Product.Price.ToString("0.00")</div>
                                    <div>€ @Model.Product.Price50.ToString("0.00")</div>
                                    <div>€ @Model.Product.Price100.ToString("0.00")</div>
                                </div>
                            </div>
                        </div>

                        <div class="product-description mt-4">
                            @Html.Raw(Model.Product.Description)
                        </div>

                        <div class="mt-4">
                            <label asp-for="Count" class="form-label quantity-label">Aantal</label>
                            <input asp-for="Count" type="number" min="1" value="1" class="form-control quantity-input" />
                            <span asp-validation-for="Count" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-3 flex-wrap mt-4">
                            <button type="submit" class="btn btn-suite-primary add-cart-btn">
                                In winkelwagen
                            </button>

                            <a asp-action="Index" class="btn btn-outline-secondary continue-btn">
                                Verder winkelen
                            </a>
                        </div>

                    </div>
                </div>

            </div>
        </div>
    </div>
</form>

