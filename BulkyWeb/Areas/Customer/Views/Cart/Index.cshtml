@model ShoppingCartVM
<link rel="stylesheet" href="~/css/cart.css" asp-append-version="true" />
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<div class="cart-wrapper">
    <div class="cart-header">
        <h1>Your Cart</h1>
        <span class="item-count">@Model.ShoppingCartList.Count() item(s)</span>
    </div>

    <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="continue-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Continue Shopping
    </a>

    <form method="post">
        <div class="cart-items">
            @foreach (var item in Model.ShoppingCartList)
            {
                <div class="cart-item">
                    <div class="item-image">
                        <img src="@item.Product.ImageUrl" alt="@item.Product.ProductName" />
                    </div>

                    <div class="item-info">
                        <p class="item-name">@item.Product.ProductName</p>
                        <p class="item-desc">@Html.Raw(item.Product.Description)</p>
                    </div>

                    <div class="item-controls">
                        <div class="item-price">
                            @item.Price.ToString("c")
                            <span class="price-count">× @item.Count</span>
                        </div>
                        <div class="item-actions">
                            <a asp-action="plus" asp-route-cartId="@item.Id" class="qty-btn" title="Increase">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                                </svg>
                            </a>
                            <a asp-action="minus" asp-route-cartId="@item.Id" class="qty-btn" title="Decrease">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4" />
                                </svg>
                            </a>
                            <a asp-action="remove" asp-route-cartId="@item.Id" class="remove-btn" title="Remove">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="cart-summary">
            <div class="summary-row">
                <span class="summary-label">Subtotal</span>
                <span class="summary-value">@Model.OrderHeader.OrderTotal.ToString("c")</span>
            </div>
            <div class="summary-row">
                <span class="summary-label">Shipping</span>
                <span class="summary-note">Calculated at checkout</span>
            </div>
            <div class="summary-divider"></div>
            <div class="summary-row">
                <span class="total-label">Total</span>
                <span class="total-amount">@Model.OrderHeader.OrderTotal.ToString("c")</span>
            </div>
            <a asp-action="Summary" class="checkout-btn"><span>Proceed to Checkout</span></a>
        </div>
    </form>
</div>
