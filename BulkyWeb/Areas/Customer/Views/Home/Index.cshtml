@model IEnumerable<Product>

<div class="container py-5">
    <div class="row g-4">
        @foreach (var product in Model)
        {
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="product-card shadow-sm">
                    <div class="product-image-container">
                        <img src="@product.ImageUrl" class="product-image" alt="@product.ProductName" />
                    </div>

                    <div class="card-body d-flex flex-column p-4">
                        <div class="mb-2">
                            <span class="ean-badge">EAN: @product.EAN</span>
                        </div>

                        <h5 class="card-title text-dark fw-bold mb-3" style="font-size: 1.1rem;">
                            @product.ProductName
                        </h5>

                        <div class="mt-auto">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="text-muted text-decoration-line-through small">@product.ListPrice.ToString("c")</span>
                                <span class="fw-bold text-primary h5 mb-0">@product.Price100.ToString("c")</span>
                            </div>

                            <a asp-action="Details" asp-route-productId="@product.Id" class="btn-suite-primary d-block">
                                Bekijk Product
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
