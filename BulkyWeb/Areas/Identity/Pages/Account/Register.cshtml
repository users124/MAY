@page
@model RegisterModel

@using System.Security.Claims
@{
    // We zoeken de claim die de rol bevat
    var roleName = User.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role)?.Value;
}

<div class="container d-flex justify-content-center align-items-center flex-grow-1" style="min-height: 80vh; padding-top: 50px; padding-bottom: 50px;">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-lg border-0" style="border-radius: 20px; overflow: hidden;">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    @if (User.IsInRole(SD.Role_Admin) || User.IsInRole(SD.Role_Employee))
                    {
                        <h2 class="fw-bold text-dark">Nieuwe Gebruiker</h2>
                        <span class="badge bg-soft-primary text-primary px-3 py-2 mt-2" style="background-color: #e7f1ff;">ADMIN PORTAL</span>
                    }
                    else
                    {
                        <h2 class="fw-bold text-dark">Account aanmaken</h2>
                        <p class="text-muted">Sluit je aan bij de MAY Business Suite</p>
                    }
                </div>

                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="row g-3">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                    <div class="form-floating col-md-12 mb-2">
                        <input asp-for="Input.Email" class="form-control border-0 bg-light shadow-sm" style="border-radius: 12px;" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                        <label asp-for="Input.Email" class="ms-2 text-muted">Emailadres</label>
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div class="form-floating col-md-6 mb-2">
                        <input asp-for="Input.Name" class="form-control border-0 bg-light shadow-sm" style="border-radius: 12px;" placeholder="Naam" />
                        <label asp-for="Input.Name" class="ms-2 text-muted">Volledige Naam</label>
                        <span asp-validation-for="Input.Name" class="text-danger small"></span>
                    </div>

                    <div class="form-floating col-md-6 mb-2">
                        <input asp-for="Input.PhoneNumber" class="form-control border-0 bg-light shadow-sm" style="border-radius: 12px;" placeholder="Telefoon" />
                        <label asp-for="Input.PhoneNumber" class="ms-2 text-muted">Telefoonnummer</label>
                        <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
                    </div>

                    <div class="form-floating col-md-6 mb-2">
                        <input asp-for="Input.Password" class="form-control border-0 bg-light shadow-sm" style="border-radius: 12px;" autocomplete="new-password" aria-required="true" placeholder="password" />
                        <label asp-for="Input.Password" class="ms-2 text-muted">Wachtwoord</label>
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="form-floating col-md-6 mb-2">
                        <input asp-for="Input.ConfirmPassword" class="form-control border-0 bg-light shadow-sm" style="border-radius: 12px;" autocomplete="new-password" aria-required="true" placeholder="password" />
                        <label asp-for="Input.ConfirmPassword" class="ms-2 text-muted">Bevestig Wachtwoord</label>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="form-floating col-md-12 mb-2">
                        <input asp-for="Input.StreetAddress" class="form-control border-0 bg-light shadow-sm" style="border-radius: 12px;" placeholder="Straat" />
                        <label asp-for="Input.StreetAddress" class="ms-2 text-muted">Straat & Huisnummer</label>
                        <span asp-validation-for="Input.StreetAddress" class="text-danger small"></span>
                    </div>

                    <div class="form-floating col-md-6 mb-2">
                        <input asp-for="Input.City" class="form-control border-0 bg-light shadow-sm" style="border-radius: 12px;" placeholder="Stad" />
                        <label asp-for="Input.City" class="ms-2 text-muted">Stad</label>
                        <span asp-validation-for="Input.City" class="text-danger small"></span>
                    </div>

                    <div class="form-floating col-md-6 mb-2">
                        <input asp-for="Input.PostalCode" class="form-control border-0 bg-light shadow-sm" style="border-radius: 12px;" placeholder="Postcode" />
                        <label asp-for="Input.PostalCode" class="ms-2 text-muted">Postcode</label>
                        <span asp-validation-for="Input.PostalCode" class="text-danger small"></span>
                    </div>

                    @if (User.IsInRole(SD.Role_Admin))
                    {
                        <div class="form-floating col-md-6 mb-2">
                            <select asp-for="Input.Role" asp-items="@Model.Input.RoleList" class="form-select border-0 bg-light shadow-sm" style="border-radius: 12px;">
                                <option disabled selected>-Selecteer Rol-</option>
                            </select>
                            <label asp-for="Input.Role" class="ms-2 text-muted">Rol</label>
                        </div>
                        <div class="form-floating col-md-6 mb-2">
                            <select asp-for="Input.CompanyId" style="display:none; border-radius: 12px;" asp-items="@Model.Input.CompanyList" class="form-select border-0 bg-light shadow-sm">
                                <option disabled selected>-Selecteer Bedrijf-</option>
                            </select>
                            <label asp-for="Input.CompanyId" class="ms-2 text-muted">Bedrijf</label>
                        </div>
                    }

                    <div class="col-12 mt-4">
                        <button id="registerSubmit" type="submit" class="btn btn-primary w-100 py-3 shadow-sm border-0 bg-gradient rounded-3 text-uppercase fw-bold" style="background-color: var(--primary-dark) !important;">
                            Registreren
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            $('#Input_Role').change(function () {
                var selection = $('#Input_Role option:selected').text();
                if(selection == 'Company'){
                    $('#Input_CompanyId').show();
                }
                else{
                    $('#Input_CompanyId').hide();
                }
            });
        });
    </script>
}
